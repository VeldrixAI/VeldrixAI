# ══════════════════════════════════════════════════════════════════════════════
# VeldrixAI Backend — Shared Environment Configuration
# Used by: auth (port 8000) · core (port 8001) · connectors (port 8002)
# Copy to .env and fill in your values. Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (auth + connectors) ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/veldrix_auth

# ── JWT (all services) ────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development

# ── NVIDIA NIM (core) ────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Per-pillar model assignments (core) ──────────────────────────────────────
VELDRIX_PILLAR_CONTENT_MODEL=meta/llama-guard-4-12b
VELDRIX_PILLAR_HALLUCINATION_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_BIAS_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_POLICY_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_LEGAL_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_NIM_TIMEOUT_MS=8000
VELDRIX_MAX_INPUT_CHARS=2000

# ── VeldrixAI internal auth (core) ───────────────────────────────────────────
VELDRIX_INTERNAL_API_KEY=generate_a_strong_secret_here

# ── Stripe billing (auth) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROW_MONTHLY=price_...
STRIPE_PRICE_GROW_ANNUAL=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_ANNUAL=price_...
VELDRIX_UI_URL=http://localhost:5000

# ── AES-256 Vault (auth + connectors) ────────────────────────────────────────
# 256-bit key for at-rest encryption of secrets and credentials.
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# NEVER commit a real key. Use a secrets manager in production.
VELDRIX_VAULT_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# ── AWS S3 (connectors) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=veldrixai-reports
