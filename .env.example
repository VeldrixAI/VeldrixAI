# =============================================================================
# VeldrixAI — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ── Authentication Service (backend/auth) ─────────────────────────────────────
DATABASE_URL=postgresql+psycopg://DB:veldrix_dev_password@postgres:<port_number>/veldrix_auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_GROW_MONTHLY=price_xxx
STRIPE_PRICE_GROW_ANNUAL=price_xxx
STRIPE_PRICE_SCALE_MONTHLY=price_xxx
STRIPE_PRICE_SCALE_ANNUAL=price_xxx

# ── Inference Provider Registry ───────────────────────────────────────────────
# Providers are tried in priority order. Any provider whose key / URL is absent
# is silently excluded from the active registry at startup.

# Priority 1: NVIDIA NIM (recommended primary — llama-guard + llama-3.1 models)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=meta/llama-3.1-70b-instruct

# Per-pillar NIM model overrides (forwarded only when NIM is the active provider)
VELDRIX_PILLAR_CONTENT_MODEL=meta/llama-guard-4-12b
VELDRIX_PILLAR_HALLUCINATION_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_BIAS_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_POLICY_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_PILLAR_LEGAL_MODEL=meta/llama-3.1-8b-instruct
VELDRIX_NIM_TIMEOUT_MS=8000

# Priority 2: Groq (fast fallback — free tier available at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Priority 3: AWS Bedrock proxy (optional — enterprise / regulated deployments)
# Requires an OpenAI-compatible proxy (bedrock-access-gateway or LiteLLM)
BEDROCK_PROXY_URL=
BEDROCK_API_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Priority 4: OSS local fallback (optional — air-gapped / zero-egress deployments)
# Requires a running vLLM or Ollama instance with OpenAI-compatible API
OSS_INFERENCE_URL=
OSS_API_KEY=
OSS_MODEL_ID=llama3.1:8b

# ── Circuit Breaker Configuration ─────────────────────────────────────────────
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60
CIRCUIT_HALF_OPEN_SUCCESS_REQUIRED=2

# Internal service authentication
VELDRIX_INTERNAL_API_KEY=vx-internal-dev-key
VELDRIX_CONNECTORS_URL=http://localhost:8002

# Inter-service URLs (core service → auth, connectors)
VELDRIX_AUTH_URL=http://localhost:8000

# CORS allowed origins for the core service (comma-separated)
VELDRIX_CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ── Connectors Service (backend/connectors) ───────────────────────────────────
# AWS S3 — DEPRECATED: report generation streams directly, no object storage required
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET_NAME=

# ── AES-256 Vault ───────────────────────────────────────────────────────────
# 256-bit key for at-rest encryption of secrets and credentials.
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# NEVER commit a real key. Use a secrets manager in production.
VELDRIX_VAULT_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# ── Frontend (frontend/) ──────────────────────────────────────────────────────
VELDRIX_AUTH_API_URL=http://localhost:8000
VELDRIX_CORE_API_URL=http://localhost:8001
VELDRIX_CONNECTORS_API_URL=http://localhost:8002
# Client-side public vars (prefixed NEXT_PUBLIC_ — safe to expose to browser)
NEXT_PUBLIC_VELDRIX_CORE_URL=http://localhost:8001
JWT_SECRET=change-me-in-production
