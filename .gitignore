# ── Secrets & Environment ──────────────────────────────────────────────────────
.env
.env.*
*.env
!.env.example
!.env.local.example
# Explicit allow for checked-in example files
!backend/.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log
*.db
*.sqlite
*.sqlite3
.venv/
venv/
env/
Lib/
Scripts/
Include/
pyvenv.cfg

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
.vercel/
frontend/tsconfig.tsbuildinfo
.turbo/

# ── Playwright / Test Artifacts ───────────────────────────────────────────────
test-results/
playwright-report/
frontend/tests/reports/html/
frontend/tests/reports/*.xml
frontend/tests/reports/*.json
# Allow gitkeep placeholders that preserve empty CI output dirs
!frontend/frontend/tests/reports/.gitkeep
!frontend/frontend/tests/screenshots/.gitkeep

# ── Certificates & Keys ───────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
*.jks

# ── Misc ──────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
.DS_Store
Thumbs.db
